# ===================================
# EduClips — Environment Variables
# ===================================
# Copy this file to .env and fill in your values

# -------- Required --------
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# -------- Optional --------
# Use "true" to use OpenAI hosted Whisper API (cheaper, faster)
# Use "false" to use local Whisper model (free, slower, needs more RAM)
USE_OPENAI_API=true

# Number of clips to generate (3-5 recommended)
NUM_CLIPS=5

# Clip duration range in seconds
CLIP_MIN_SECONDS=20
CLIP_MAX_SECONDS=60

# Server settings
HOST=0.0.0.0
PORT=8000
